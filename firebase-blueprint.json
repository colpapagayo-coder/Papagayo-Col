{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Represents a Colombian product imported by Papagayo.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique product ID"
        },
        "name": {
          "type": "string",
          "description": "Name of the product"
        },
        "description": {
          "type": "string"
        },
        "base64Image": {
          "type": "string",
          "description": "Base64 encoded image string (downscaled to <1MB)"
        },
        "departmentCode": {
          "type": "string",
          "description": "The administrative department code in Colombia for mapping"
        },
        "ownerId": {
          "type": "string",
          "description": "UID of the user who created it"
        },
        "createdAt": {
          "type": "number",
          "description": "Server timestamp"
        }
      },
      "required": ["name", "description", "departmentCode", "ownerId", "base64Image"]
    },
    "ProductRequest": {
      "title": "ProductRequest",
      "description": "Represents a customer request/suggestion for a product.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the person making the suggestion"
        },
        "email": {
          "type": "string",
          "description": "Email of the person making the suggestion"
        },
        "requestedProduct": {
          "type": "string",
          "description": "Description of the product they are looking for"
        },
        "createdAt": {
          "type": "object",
          "description": "Server timestamp of creation"
        }
      },
      "required": ["name", "email", "requestedProduct", "createdAt"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "Collection of all products."
    },
    "product_requests/{requestId}": {
      "schema": {
        "$ref": "#/entities/ProductRequest"
      },
      "description": "Collection of client product suggestions."
    }
  }
}
